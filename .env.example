# PostgreSQL
POSTGRES_USER=quotes
POSTGRES_PASSWORD=change_me
POSTGRES_DB=quotes

# Application DB URL (inside docker network, host is 'db')
DATABASE_URL=postgres://quotes:change_me@db:5432/quotes?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_S=300

# FX API
FX_API_URL=https://api.exchangeratesapi.io/v1
FX_API_KEY=change_me
FX_API_TIMEOUT_MS=5000

# HTTP
HTTP_ADDR=:8080
WORKER_COUNT=1
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_MS=500
POLL_INTERVAL_MS=1000
BATCH_SIZE=10
JOB_TIMEOUT_MS=30000
MAX_CLAIM_ATTEMPTS=5
# 0 = auto (2 × JOB_TIMEOUT_MS)
STALE_AFTER_MS=0
